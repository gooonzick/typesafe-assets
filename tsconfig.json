{
  "compilerOptions": {
    "target": "es2022",
    "useDefineForClassFields": true,
    "module": "esnext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@gooonzick/typesafe-assets-core": ["packages/core/src/index.ts"],
      "@gooonzick/typesafe-assets-vite": ["packages/vite/src/index.ts"],
      "@gooonzick/typesafe-assets-webpack": ["packages/webpack/src/index.ts"],
      "@gooonzick/typesafe-assets-eslint": ["packages/eslint/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["packages", "src", "tests"],
  "exclude": ["tests/fixtures/**", "packages/**/tests/fixtures/**"]
}
